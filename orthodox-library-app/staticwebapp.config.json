{
  "platform": {
    "apiRuntime": "node:22"
  },
  "routes": [
    {
      "route": "/",
      "rewrite": "/index"
    },
    {
      "route": "/_next/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index",
    "exclude": ["/_next/*", "/images/*", "/*.ico", "/*.png", "/*.svg", "/*.json"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".woff": "font/woff",
    ".woff2": "font/woff2"
  }
}
