# Example environment variables for Orthodox Library
# Copy this file to .env (or set variables in your deployment platform)

# Backend API URL (where the Express server/church-management backend is running)
# Local Development: http://localhost:3001
# Production: https://api.erotc.org or https://cms.erotc.org
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Specify a custom port (Next.js default is 3000)
#PORT=3000

# Add any application-specific variables here, such as:
# DATABASE_URL=mongodb://user:pass@host:port/dbname
# NEXTAUTH_URL=https://yourdomain.com
# NEXT_PUBLIC_ANALYTICS_ID=UA-XXXXX-Y

# Increase Node.js memory if build fails with OOM; not needed in production platforms usually
# NODE_OPTIONS="--max-old-space-size=4096"
